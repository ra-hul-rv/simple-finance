generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  SAVINGS
  CURRENT
  CASH
  CREDIT_CARD
  DEBIT_CARD
  FIXED_DEPOSIT
  STOCKS
  MUTUAL_FUNDS
  CRYPTO
  LOAN
  EPF
  PPF
  NPS
  OTHER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
  CREDIT_CARD_PAYMENT
  REFUND
  INTEREST
  DIVIDEND
}

enum TransactionStatus {
  COMPLETED
  PENDING
  CANCELLED
  RECURRING
}

enum InboxEventStatus {
  PENDING
  PROCESSED
  DISMISSED
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum InvestmentType {
  STOCKS
  MUTUAL_FUNDS
  GOLD
  CRYPTO
  FIXED_DEPOSIT
  BONDS
  EPF
  PPF
  NPS
  OTHER
}

enum NotificationType {
  BILL_DUE
  CREDIT_CARD_DUE
  FD_MATURITY
  SUBSCRIPTION_RENEWAL
  LARGE_EXPENSE
  BUDGET_EXCEEDED
  GENERAL
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  transactions          Transaction[]
  categories            Category[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  subscriptions         Subscription[]
  investments           Investment[]
  creditCards           CreditCard[]
  fixedDeposits         FixedDeposit[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  settings              UserSettings?
  tags                  Tag[]
  debts                 Debt[]
  loans                 Loan[]
  shoppingLists         ShoppingList[]
  warranties            Warranty[]
  coupons               Coupon[]
  automationRules       AutomationRule[]
  flowTypes             FlowType[]
  templates             TransactionTemplate[]
  inboxEvents           InboxEvent[]
  people                Person[]
  emis                  Emi[]
}

model UserSettings {
  id         String   @id @default(uuid())
  currency   String   @default("INR")
  dateFormat String   @default("dd/MM/yyyy")
  locale     String   @default("en-IN")
  theme      String   @default("system")
  showDashboardCharts  Boolean @default(true)
  showAccountsCharts   Boolean @default(true)
  showBillsCharts      Boolean @default(true)
  showAttachments      Boolean @default(true)
  sidebarOrder         String?
  sidebarSectionLabels String?
  webhookToken         String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id             String        @id @default(uuid())
  name           String
  type           AccountType
  institution    String?
  accountNumber  String?
  balance        Decimal       @default(0) @db.Decimal(15, 2)
  openingBalance Decimal       @default(0) @db.Decimal(15, 2)
  currency       String        @default("INR")
  interestRate   Decimal?      @db.Decimal(5, 2)
  creditLimit    Decimal?      @db.Decimal(15, 2)
  closingDate    Int?
  dueDate        Int?
  color          String        @default("#6366f1")
  icon           String        @default("wallet")
  notes          String?
  status         AccountStatus @default(ACTIVE)
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  transfersTo           Transaction[]         @relation("TransferToAccount")
  recurringTransactions RecurringTransaction[]
  subscriptions         Subscription[]
  creditCard            CreditCard?
  debts                 Debt[]
  loans                 Loan[]
  emis                  Emi[]

  @@index([userId])
  @@index([type])
}

model Transaction {
  id          String            @id @default(uuid())
  date        DateTime          @default(now())
  amount      Decimal           @db.Decimal(15, 2)
  type        TransactionType
  flowType    String?
  description String?
  merchant    String?
  location    String?
  notes       String?
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  accountId              String
  account                Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId             String?
  category               Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transferToAccountId    String?
  transferToAccount      Account?              @relation("TransferToAccount", fields: [transferToAccountId], references: [id], onDelete: SetNull)
  recurringTransactionId String?
  recurringTransaction   RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id], onDelete: SetNull)

  tags TransactionTag[]
  attachments TransactionAttachment[]

  personId               String?
  person                 Person?               @relation(fields: [personId], references: [id], onDelete: SetNull)
  loanId                 String?
  loan                   Loan?                 @relation(fields: [loanId], references: [id], onDelete: SetNull)
  emiPayment             EmiPayment?

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@index([type])
}

model Category {
  id           String       @id @default(uuid())
  name         String
  type         CategoryType
  color        String       @default("#6366f1")
  icon         String       @default("tag")
  description  String?
  budgetAmount Decimal?     @db.Decimal(15, 2)
  order        Int          @default(0)
  isActive     Boolean      @default(true)
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  subscriptions         Subscription[]

  @@index([userId])
  @@index([parentId])
  @@index([type])
}

model Tag {
  id        String           @id @default(uuid())
  name      String
  color     String           @default("#6366f1")
  createdAt DateTime         @default(now())

  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model RecurringTransaction {
  id                String          @id @default(uuid())
  name              String
  amount            Decimal         @db.Decimal(15, 2)
  type              TransactionType
  frequency         Frequency
  startDate         DateTime
  endDate           DateTime?
  nextDate          DateTime
  lastGeneratedDate DateTime?
  isActive          Boolean         @default(true)
  description       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  generatedTransactions Transaction[]

  @@index([userId])
  @@index([nextDate])
}

model Subscription {
  id          String             @id @default(uuid())
  service     String
  monthlyCost Decimal            @db.Decimal(15, 2)
  annualCost  Decimal?           @db.Decimal(15, 2)
  renewalDate DateTime
  status      SubscriptionStatus @default(ACTIVE)
  description String?
  url         String?
  icon        String?
  color       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  accountId  String?
  account    Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([renewalDate])
}

model Budget {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(15, 2)
  spent     Decimal  @default(0) @db.Decimal(15, 2)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@index([month, year])
}

model Investment {
  id             String         @id @default(uuid())
  name           String
  type           InvestmentType
  investedAmount Decimal        @db.Decimal(15, 2)
  currentValue   Decimal        @db.Decimal(15, 2)
  units          Decimal?       @db.Decimal(15, 6)
  purchaseDate   DateTime
  notes          String?
  platform       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model CreditCard {
  id                 String   @id @default(uuid())
  cardName           String
  lastFourDigits     String?
  cardNumber         String?
  cardHolderName     String?
  expiryDate         String?
  cvv                String?
  template           String?  @default("STANDARD")
  notes              String?  @db.Text
  creditLimit        Decimal  @db.Decimal(15, 2)
  outstandingBalance Decimal  @default(0) @db.Decimal(15, 2)
  availableCredit    Decimal  @db.Decimal(15, 2)
  dueDate            Int?
  statementDate      Int?
  minimumDue         Decimal? @db.Decimal(15, 2)
  interestRate       Decimal? @db.Decimal(5, 2)
  rewardsBalance     Decimal  @default(0) @db.Decimal(15, 2)
  color              String   @default("#6366f1")
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FixedDeposit {
  id             String   @id @default(uuid())
  bankName       String
  principal      Decimal  @db.Decimal(15, 2)
  interestRate   Decimal  @db.Decimal(5, 2)
  startDate      DateTime
  maturityDate   DateTime
  interestEarned Decimal  @default(0) @db.Decimal(15, 2)
  maturityAmount Decimal  @db.Decimal(15, 2)
  autoRenewal    Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([maturityDate])
}

model Notification {
  id           String           @id @default(uuid())
  type         NotificationType
  title        String
  message      String
  isRead       Boolean          @default(false)
  scheduledFor DateTime?
  createdAt    DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Debt {
  id                 String    @id @default(uuid())
  lenderName         String
  totalBorrowed      Decimal   @db.Decimal(15, 2)
  outstandingBalance Decimal   @db.Decimal(15, 2)
  dueDate            DateTime?
  interestRate       Decimal?  @db.Decimal(5, 2)
  color              String    @default("#a855f7")
  notes              String?
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Loan {
  id                 String    @id @default(uuid())
  borrowerName       String
  totalLent          Decimal   @db.Decimal(15, 2)
  outstandingBalance Decimal   @db.Decimal(15, 2)
  dueDate            DateTime?
  interestRate       Decimal?  @db.Decimal(5, 2)
  color              String    @default("#f97316")
  notes              String?
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  personId  String?
  person    Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  
  transactions Transaction[]

  @@index([userId])
  @@index([personId])
}

model TransactionAttachment {
  id            String   @id @default(uuid())
  fileName      String
  fileType      String   // "image/png", "application/pdf", etc.
  filePath      String   // relative path in /public/uploads/attachments/
  fileSize      Int      // bytes
  createdAt     DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model ShoppingList {
  id          String             @id @default(uuid())
  name        String
  color       String             @default("#ec4899")
  isCompleted Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ShoppingListItem[]

  @@index([userId])
}

model ShoppingListItem {
  id             String   @id @default(uuid())
  name           String
  estimatedPrice Decimal? @db.Decimal(15, 2)
  quantity       Int      @default(1)
  checked        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  listId String
  list   ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model Warranty {
  id            String    @id @default(uuid())
  productName   String
  purchaseDate  DateTime
  warrantyMonths Int
  expiryDate    DateTime
  purchasePrice Decimal?  @db.Decimal(15, 2)
  store         String?
  category      String?
  notes         String?   @db.Text
  receiptPath   String?
  reminderDays  Int       @default(30)
  isExpired     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Coupon {
  id            String    @id @default(uuid())
  title         String
  code          String
  discountValue Decimal?  @db.Decimal(15, 2)
  discountType  String    @default("PERCENTAGE") // "PERCENTAGE", "FLAT_AMOUNT", "FREE_SHIPPING", "OTHER"
  merchant      String
  expiryDate    DateTime?
  isUsed        Boolean   @default(false)
  notes         String?   @db.Text
  terms         String?   @db.Text
  barcodePath   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AutomationRule {
  id            String    @id @default(uuid())
  name          String
  triggerType   String    // "TRANSACTION_CREATED" or "SCHEDULED"
  isActive      Boolean   @default(true)
  conditions    Json      // JSON array of conditions: { field, operator, value }
  actions       Json      // JSON array of actions: { type, value }
  frequency     String?   // "DAILY", "WEEKLY", "MONTHLY", "YEARLY" (for SCHEDULED)
  nextExecution DateTime? // For scheduled rules
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FlowType {
  id          String   @id @default(uuid())
  name        String
  direction   String   // "INCOME" or "EXPENSE"
  color       String?  @default("#6366f1")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model TransactionTemplate {
  id            String          @id @default(uuid())
  name          String
  amount        Decimal?        @db.Decimal(15, 2)
  type          TransactionType @default(EXPENSE)
  flowType      String?
  description   String?
  merchant      String?
  location      String?
  notes         String?
  accountId     String
  categoryId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InboxEvent {
  id          String           @id @default(uuid())
  source      String           @default("n8n_mail")
  payload     Json
  status      InboxEventStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Person {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  loans        Loan[]
  emis         Emi[]

  @@index([userId])
}

model Emi {
  id              String   @id @default(uuid())
  itemName        String
  totalAmount     Decimal  @db.Decimal(15, 2)
  totalMonths     Int
  monthsPaid      Int      @default(0)
  principalAmount     Decimal? @db.Decimal(15, 2)
  interestAmount      Decimal? @db.Decimal(15, 2)
  taxOnInterest       Decimal? @db.Decimal(15, 2)
  processingFee       Decimal? @db.Decimal(15, 2)
  taxOnProcessingFee  Decimal? @db.Decimal(15, 2)
  billingDate         Int
  startDate           DateTime
  status              String   @default("ACTIVE")
  notes               String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  personId        String?
  person          Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  payments        EmiPayment[]

  @@index([userId])
  @@index([accountId])
}

model EmiPayment {
  id              String   @id @default(uuid())
  monthNumber     Int
  dueDate         DateTime
  paidDate        DateTime?
  amount          Decimal  @db.Decimal(15, 2)
  isFirstMonth    Boolean  @default(false)
  status          String   @default("PENDING")
  
  emiId           String
  emi             Emi      @relation(fields: [emiId], references: [id], onDelete: Cascade)
  transactionId   String?  @unique
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([emiId])
}
